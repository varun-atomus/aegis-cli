{
  "name": "aegis-cli",
  "version": "1.0.0",
  "description": "Atomus Aegis CLI - Device compliance monitoring for headless Linux servers",
  "main": "dist/index.js",
  "bin": {
    "aegis": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "npx ts-node src/index.ts",
    "start": "node dist/index.js",
    "daemon": "node dist/daemon.js",
    "lint": "eslint src/",
    "clean": "rm -rf dist/",
    "package": "npm run build && pkg dist/index.js --targets node18-linux-x64 --output bin/aegis"
  },
  "author": "Atomus Corporation",
  "license": "UNLICENSED",
  "dependencies": {
    "@azure/msal-node": "^2.6.0",
    "axios": "^1.6.5",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "dayjs": "^1.11.10",
    "lodash": "^4.17.21",
    "ora": "^5.4.1",
    "toad-scheduler": "^3.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.11.5",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
